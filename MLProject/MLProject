name: obesity_ci

conda_env: conda.yaml

entry_points:
  main:
    parameters:
      data_path: {type: str, default: "obesity_preprocessing.csv"}
      n_estimators: {type: int, default: 300}
      max_depth: {type: int, default: 0}
    command: "python modelling.py --data_path {data_path} --n_estimators {n_estimators} --max_depth {max_depth}"
